<?xml version="1.0" encoding="Windows-1252"?>
<VisualStudioProject
	ProjectType="Visual C++"
	Version="8.00"
	Name="FZDUMP"
	ProjectGUID="{B6B7F7D9-3D3B-4B84-8C7B-6A7A0C3CEB8B}"
	RootNamespace="FZDUMP"
	Keyword="Win32Proj"
	>
	<Platforms>
		<Platform
			Name="Win32"
		/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="Debug|Win32"
			OutputDirectory="$(SolutionDir)$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="1"
			CharacterSet="1"
			>
			<Tool
				Name="VCCLCompilerTool"
				WarningLevel="3"
				Detect64BitPortabilityProblems="false"
				PreprocessorDefinitions="_CRT_SECURE_NO_DEPRECATE;_CRT_NONSTDC_NO_DEPRECATE"
				Optimization="0"
				DebugInformationFormat="4"
			/>
			<Tool
				Name="VCLinkerTool"
				GenerateDebugInformation="true"
			/>
		</Configuration>
		<Configuration
			Name="Release|Win32"
			OutputDirectory="$(SolutionDir)$(ConfigurationName)"
			IntermediateDirectory="$(ConfigurationName)"
			ConfigurationType="1"
			CharacterSet="1"
			WholeProgramOptimization="1"
			>
			<Tool
				Name="VCCLCompilerTool"
				WarningLevel="3"
				Detect64BitPortabilityProblems="false"
				PreprocessorDefinitions="_CRT_SECURE_NO_DEPRECATE;_CRT_NONSTDC_NO_DEPRECATE"
				Optimization="2"
				RuntimeLibrary="2"
				DebugInformationFormat="0"
			/>
			<Tool
				Name="VCLinkerTool"
				GenerateDebugInformation="true"
			/>
		</Configuration>
	</Configurations>
	<Files>
		<Filter
			Name="Source Files"
			Filter="cpp;c;cc;cxx;def;odl;idl;hpj;bat;asm;asmx"
			>
			<File
				RelativePath=".\FZDUMP.CPP"
				>
			</File>
			<File
				RelativePath=".\FZ_PORT.CPP"
				>
			</File>
			<File
				RelativePath=".\PC_DISK.CPP"
				>
			</File>
			<File
				RelativePath=".\PORT_IO.CPP"
				>
			</File>
			<File
				RelativePath=".\ST_DEV.CPP"
				>
			</File>
		</Filter>
		<Filter
			Name="Header Files"
			Filter="h;hpp;hxx;hm;inl;inc;xsd"
			>
			<File
				RelativePath=".\CASIO.H"
				>
			</File>
			<File
				RelativePath=".\PORT_IO.H"
				>
			</File>
			<File
				RelativePath=".\ST_DEV.H"
				>
			</File>
			<File
